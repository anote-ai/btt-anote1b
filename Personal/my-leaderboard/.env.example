# Leaderboard API (FastAPI) — copy to `.env` and fill in.
# Committed to git; `.env` is ignored.

# LEADERBOARD_AUTH_MODE=off
# GOOGLE_OAUTH_CLIENT_ID=your-id.apps.googleusercontent.com
# ANOTE_JWT_SECRET=
# Include localhost when using a custom list (required for Vite dev):
# LEADERBOARD_CORS_ORIGINS=http://localhost:3000,https://your-prod-leaderboard.example
# Override DB path only if needed; default is my-leaderboard/leaderboard.db (stable cwd).
# DATABASE_URL=sqlite:////absolute/path/to/leaderboard.db
