# Vite frontend — copy to `.env` and fill in.
# Committed to git; `.env` is ignored.

# VITE_API_URL=http://localhost:8000
# VITE_API_WITH_CREDENTIALS=true
# Optional extra “Open app” link only (default: none — use /login for Google).
# VITE_ANOTE_SIGNIN_URL=https://example.com
# VITE_GOOGLE_CLIENT_ID=your-id.apps.googleusercontent.com
# (alias) VITE_GOOGLE_OAUTH_CLIENT_ID=same-as-backend-GOOGLE_OAUTH_CLIENT_ID
